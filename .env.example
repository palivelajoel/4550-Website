# Example .env for local development. Copy to .env and fill values.
# For Vite, client-exposed variables must begin with VITE_. Only expose the anon/public key to the browser.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key-here
VITE_TEAM_PASSWORD=Bruin@4550
VITE_ADMIN_PASSWORD=Admin@4550

# Server-side keys (do NOT prefix with VITE_). These belong in your deployment environment only.
# GROQ_API_KEY=your_groq_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# JWT_SECRET=generate-a-random-secret-string-for-signing-tokens
